    {
      "parameters": {
        "jsCode": "// Retrieval response\nconst retrieval = $('Get Tables and Columns').first().json;\n\nconst selectedTables = retrieval.selected_tables || [];\nconst selectedColumns = retrieval.selected_columns || [];\nconst joins = retrieval.joins || [];\n\nconst schemaMap = {};\nfor (const key of selectedTables) {\n  schemaMap[key] = {\"columns\": []};\n}\nfor(const col of selectedColumns) {\n  schemaMap[col[\"table\"]][\"columns\"].push(col[\"column\"]);\n}\n\nreturn [{\n    json: {\n        question: $('Webhook').first().json.query,\n        schemaMap: schemaMap,\n        selected_tables: selectedTables,\n        selected_columns: selectedColumns,\n        joins: joins,\n        index: 0\n    }\n}];"
